@inject Application.Interfaces.Services.ISettingsService Settings

@{
    var isAdmin = User.IsInRole("admin");
    var isOperator = User.IsInRole("operator");
    
    var name = await Settings.GetSettingByNameAsync("Название организации");
    var color = await Settings.GetSettingByNameAsync("Основной цвет");
    var logo = await Settings.GetSettingByNameAsync("Логотип");
    var address = await Settings.GetSettingByNameAsync("Адрес");
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <style>:root { --color-primary: @color.Value; }</style>
</head>
<body class="font-display bg-surface h-screen flex">

<aside id="nav" class="w-72 shrink-0 flex flex-col bg-primary-deep">
    <div class="flex items-center gap-3 p-5 border-b border-b-primary/30">
        @if (!string.IsNullOrEmpty(logo!.Value))
        {
            <img src="@logo.Value" alt="logo" class="h-12 w-12"/>
        }
        else
        {
            <div class="bg-primary text-2xl text-white rounded-lg px-3 py-1.5 font-bold">О</div>
        }
        <div class="flex flex-col tracking-wide">
            <div class="label font-bold uppercase text-white text-lg">@name!.Value</div>
            <div class="label text-sm text-white/60">@address!.Value</div>
        </div>
    </div>

    <nav  class="w-72 flex-1 overflow-y-auto px-3 py-5 flex flex-col justify-between gap-6 text-white">
        <div class="flex flex-col gap-2 pt-2">
            @if (isOperator || isAdmin)
            {
                <a asp-controller="Operator" asp-action="Index" class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    <span class="label">Рабочее место</span>
                </a>
            }

            @if (isAdmin)
            {
                <a asp-controller="Admin" asp-action="WindowsList"   class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    <span class="label">Окна</span>
                </a>
                <a asp-controller="Admin" asp-action="UserList" class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    <span class="label">Сотрудники</span>
                </a>
                <a asp-controller="Admin" asp-action="ServiceList" class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                    <span class="label">Услуги</span>
                </a>
                <a asp-controller="Admin" asp-action="Statistics" class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                    <span class="label">Статистика</span>
                </a>
                <a asp-controller="Admin" asp-action="Settings" class="flex items-center gap-3 rounded-xl px-3 py-2 text-md font-medium text-dark/80 hover:bg-primary/5 hover:text-dark transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    <span class="label">Настройки</span>
                </a>
                
            }
        </div>
        <button id="nav-toggle" type="button" class="p-2 rounded-lg text-dark/70 flex justify-end cursor-pointer w-full">
            <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-to-line-icon lucide-arrow-left-to-line text-white">
                <path d="M3 19V5"/><path d="m13 6-6 6 6 6"/><path d="M7 12h14"/>
            </svg>
        </button>
    </nav>
</aside>

<div class="flex-1 flex flex-col min-w-0">
    <header class="shrink-0 border-b border-border flex items-center justify-end p-6.5">
        <div class="flex items-center gap-3">
            @if (isAdmin)
            {
                <form asp-controller="Admin" asp-action="QueueReset" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="text-sm cursor-pointer font-medium text-destructive border border-destructive/30 rounded-lg px-3 py-1.5 hover:bg-destructive/5 transition-colors">
                        Сбросить очередь
                    </button>
                </form>
            }

            <div class="h-6 w-px bg-border"></div>

            <span class="text-sm text-secondary">@User.Identity?.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                <button type="submit" class="text-sm font-medium text-muted hover:text-white/80 transition-colors">Выйти</button>
            </form>
        </div>
    </header>

    <main class="flex-1 overflow-y-auto p-6">
        @RenderBody()
    </main>
</div>

<script>
    const sb  = document.getElementById('nav');
    const btn = document.getElementById('nav-toggle');
    const btnIcon = document.getElementById('btn-icon');

    function toggle(collapsed) {
        sb.classList.toggle('w-72', !collapsed);
        sb.classList.toggle('w-16', collapsed);
        document.querySelectorAll('.label').forEach(el => el.classList.toggle('hidden', collapsed));
        btn.classList.toggle('justify-end', !collapsed);
        btnIcon.classList.toggle("rotate-180", collapsed);
    }

    toggle(localStorage.getItem("collapsed") === '1');

    btn.addEventListener('click', function () {
        const collapsed = !sb.classList.contains('w-16');
        toggle(collapsed);
        localStorage.setItem("collapsed", collapsed ? '1' : '0');
    });
</script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@simonwep/pickr/dist/themes/classic.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@@simonwep/pickr/dist/pickr.min.js"></script>
    <script src="~/js/pickr.js" asp-append-version="true"></script>
</body>
</html>