@model Application.DTOs.EditUserDto

@{
    ViewData["Title"] = "Редактирование сотрудника";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="EditUser" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label">Имя</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Surname" class="form-label">Фамилия</label>
                <input asp-for="Surname" class="form-control" />
                <span asp-validation-for="Surname" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MiddleName" class="form-label">Отчество</label>
        <input asp-for="MiddleName" class="form-control" />
        <span asp-validation-for="MiddleName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Password" class="form-label">Пароль</label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
        <small class="text-muted">Оставьте пустым, если не хотите менять пароль</small>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Роли</label>

        <div class="roles-box">

            <label class="role-item">
                <input type="checkbox" name="roleNames" value="operator" checked disabled />
                Оператор
                <input type="hidden" name="roleNames" value="operator" />
            </label>

            <label class="role-item">
                <input type="checkbox" name="roleNames" value="admin" />
                Администратор
            </label>

        </div>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Status" class="form-label">Статус</label>
        <input asp-for="Status" class="form-control" placeholder="Активен / Неактивен" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="UserList" class="btn btn-secondary">Отмена</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}