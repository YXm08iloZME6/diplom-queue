@model Web.Models.EditUserViewModel

@{
    ViewData["Title"] = "Редактирование сотрудника";
}

<div class="min-h-screen px-6">
    <div class="max-w-4xl mx-auto">
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-800 mb-2">@ViewData["Title"]</h1>
            <p class="text-slate-500">Создание и настройка новой учётной записи</p>
        </div> 
        
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <form asp-action="EditUser" method="post" enctype="multipart/form-data" class="p-8 space-y-8">
                <div asp-validation-summary="ModelOnly" class="rounded-2xl bg-red-50 border border-red-200 text-red-600 px-4 py-3 text-sm"></div>

                <input type="hidden" asp-for="UserData.Id" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div >
                        <div>
                            <label asp-for="UserData.Name" class="block mb-2 text-sm font-semibold text-slate-700">Имя</label>
                            <input asp-for="UserData.Name" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                            <span asp-validation-for="UserData.Name" class="text-red-500 mt-1 block"></span>
                        </div>
                    </div>

                    <div>
                        <div>
                            <label asp-for="UserData.Surname" class="block mb-2 text-sm font-semibold text-slate-700">Фамилия</label>
                            <input asp-for="UserData.Surname" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                            <span asp-validation-for="UserData.Surname" class="text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div>
                    <label asp-for="UserData.MiddleName" class="block mb-2 text-sm font-semibold text-slate-700">Отчество</label>
                    <input asp-for="UserData.MiddleName" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                    <span asp-validation-for="UserData.MiddleName" class="text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label class="block mb-2 text-sm font-semibold text-slate-700">Фото профиля</label>

                    @if (!string.IsNullOrEmpty(Model.UserData.PhotoPath))
                    {
                        <div class="mb-3 flex items-center gap-4">
                            <div class="relative group">
                                <img src="@Model.UserData.PhotoPath" class="w-24 h-24 rounded-2xl object-cover border border-slate-200" />
                                <button type="button" onclick="removePhoto()" class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition">
                                    ✕
                                </button>
                            </div>

                            <span class="text-sm text-slate-500">Текущее фото. Загрузите новое чтобы заменить.</span>
                        </div>
                    }

                    <input asp-for="UserData.Photo" type="file" accept="image/*" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-600 
                    file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-blue-50 
                    file:text-blue-700 file:font-semibold hover:file:bg-blue-100 transition" />
                    <span asp-validation-for="UserData.Photo" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="UserData.Email" class="block mb-2 text-sm font-semibold text-slate-700">Email</label>
                        <input asp-for="UserData.Email" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" type="email" />
                        <span asp-validation-for="UserData.Email" class="text-red-500 mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="UserData.Password" class="block mb-2 text-sm font-semibold text-slate-700">Пароль</label>
                        <input asp-for="UserData.Password" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" type="password" />
                        <span asp-validation-for="UserData.Password" class="text-red-500 mt-1 block"></span>
                    </div>
                </div>
                

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block mb-3 text-sm font-semibold text-slate-700">Роли</label>

                        <div class="space-y-3">
                            <label class="flex items-center gap-3 p-4 rounded-2xl border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition cursor-pointer">
                                <input type="checkbox" name="Roles" value="operator" checked disabled class="w-5 h-5 rounded text-blue-600"/>
                                <span class="font-medium text-slate-700">Оператор</span>
                                <input type="hidden" name="Roles" value="operator"/>
                            </label>

                            <label class="flex items-center gap-3 p-4 rounded-2xl border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition cursor-pointer">
                                <input type="checkbox" name="Roles" value="admin" class="w-5 h-5 rounded text-blue-600" @(Model.Roles.Contains("admin") ? "checked" : "") />
                                <span class="font-medium text-slate-700">Администратор</span>
                            </label>
                        </div>
                    </div>
                    
                    <div class="space-y-6">
                        <div>
                            <label asp-for="UserData.WindowId" class="block mb-2 text-sm font-semibold text-slate-700">Окно</label>
                            <select asp-for="UserData.WindowId" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                                <option value="">Не выбрано</option>

                                @foreach (var window in Model.AvailableWindows)
                                {
                                    <option value="@window.Id">
                                        @window.Number
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="UserData.WindowId" class="text-sm text-red-500 mt-1 block"></span>
                        </div>
                    
                        <div>
                            <label asp-for="UserData.Status" class="block mb-2 text-sm font-semibold text-slate-700">Статус</label>
                            <select asp-for="UserData.Status"
                                    asp-items="Html.GetEnumSelectList<Domain.Enums.UserStatus>()"
                                    class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                            </select>
                            <span asp-validation-for="UserData.Status" class="text-sm text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-4 pt-4">
                    <button type="submit" class="px-6 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition shadow-sm">Сохранить</button>
                    <a asp-action="UserList" class="px-6 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold transition">Отмена</a>
                </div>
            </form> 
        </div>
    </div>
</div>


<form id="removePhotoForm" asp-action="RemovePhoto" method="post" class="hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.UserData.Id" />
</form>


<script>
    function removePhoto() {
        if (confirm('Удалить фотографию?')) {
            document.getElementById('removePhotoForm').submit();
        }
    }
</script>

