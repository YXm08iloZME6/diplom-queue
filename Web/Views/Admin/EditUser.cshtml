@model Web.Models.EditUserViewModel

@{
    ViewData["Title"] = "Редактирование сотрудника";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="EditUser" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="UserData.Id" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="UserData.Name" class="form-label">Имя</label>
                <input asp-for="UserData.Name" class="form-control" />
                <span asp-validation-for="UserData.Name" class="text-danger"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="UserData.Surname" class="form-label">Фамилия</label>
                <input asp-for="UserData.Surname" class="form-control" />
                <span asp-validation-for="UserData.Surname" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserData.MiddleName" class="form-label">Отчество</label>
        <input asp-for="UserData.MiddleName" class="form-control" />
        <span asp-validation-for="UserData.MiddleName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserData.Email" class="form-label">Email</label>
        <input asp-for="UserData.Email" class="form-control" type="email" />
        <span asp-validation-for="UserData.Email" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserData.Password" class="form-label">Пароль</label>
        <input asp-for="UserData.Password" class="form-control" type="password" />
        <span asp-validation-for="UserData.Password" class="text-danger"></span>
        <small>Оставьте пустым, если не хотите менять пароль</small>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Роли</label>

        <div class="roles-box">

            <label class="role-item">
                <input type="checkbox" name="Roles" value="operator" checked disabled />
                Оператор
                <input type="hidden" name="Roles" value="operator" />
            </label>

            <label class="role-item">
                <input type="checkbox" name="Roles" value="admin" />
                Администратор
            </label>

        </div>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserData.WindowId" class="form-label">Окно</label>

        <select asp-for="UserData.WindowId" class="form-select">
            <option value="">Не выбрано</option>

            @foreach (var window in Model.AvailableWindows)
            {
                <option value="@window.Id">
                    @window.Number
                </option>
            }
        </select>

        <span asp-validation-for="UserData.WindowId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserData.Status" class="form-label">Статус</label>
        <select asp-for="UserData.Status"
                asp-items="Html.GetEnumSelectList<Domain.Enums.UserStatus>()"
                class="form-select">
        </select>
        <span asp-validation-for="UserData.Status" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="UserList" class="btn btn-secondary">Отмена</a>
    </div>
</form>