@model List<Application.DTOs.UserDto>

@{
    ViewData["Title"] = "Список сотрудников";
}

<div class="flex flex-col">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Список сотрудников</h1>
            <p class="text-slate-500 mt-2">Управление сотрудниками</p>
        </div>

        <a asp-controller="Admin" asp-action="AddUser" class="flex items-center gap-4 text-white bg-primary rounded-xl py-2 px-4 border cursor-pointer">
            <span class="text-2xl">+</span>Добавить сотрудника
        </a>
    </div>

    <div class="grid grid-cols-3 gap-6">
        @foreach (var user in Model)
        {
            <div class="bg-white rounded-2xl p-5 border border-line flex flex-col gap-3">
                <div class="flex justify-between">
                    <div class="flex flex-col">
                        <div class="rounded-full">
                            @user.Surname[0]@user.Name[0]
                        </div>
                        <span>@user.Surname @user.Name</span>
                        <span>@user.</span>
                    </div>
                    
                    <div class="flex gap-4">
                        <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class=""> 
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-line-icon lucide-pencil-line"><path d="M13 21h8"/><path d="m15 5 4 4"/><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
                         </a> 
                         <form asp-action="RemoveUser" method="post" style="display:inline;" class=""> 
                             <input type="hidden" name="id" value="@user.Id"/>
                             <button type="submit" onclick="return confirm('Удалить пользователя?')">
                                 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2-icon lucide-trash-2"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                             </button>
                         </form> 
                    </div>
                </div>
                
                <div>
                    
                </div>
                
                <div>
                    
                </div>
            </div>
        }
        
        
        
        
