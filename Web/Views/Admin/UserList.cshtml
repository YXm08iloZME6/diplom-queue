@using Domain.Entities
@model List<Application.DTOs.UserDto>

@{
    ViewData["Title"] = "Список сотрудников";
}

<div class="flex flex-col">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Список сотрудников</h1>
            <p class="text-slate-500 mt-2">Управление сотрудниками</p>
        </div>

        
    </div>

    <div class="grid grid-cols-3 gap-6 auto-rows-fr">
        @foreach (var user in Model)
        {
            <div class="bg-white rounded-2xl p-5 border border-line flex flex-col gap-5">
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-4">
                        <div class="flex justify-center items-center h-12 w-12 rounded-full overflow-hidden bg-primary-soft font-semibold font-mono tracking-widest flex-shrink-0">
                            @if (!string.IsNullOrEmpty(user.PhotoPath))
                            {
                                <img src="@user.PhotoPath" alt="@user.Surname @user.Name" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <span class="text-primary">@user.Surname[0]@user.Name[0]</span>
                            }
                        </div>
                        <div class="flex flex-col">
                            <span class="font-semibold">@user.Surname @user.Name</span>
                            <div class="flex gap-4">
                                @if (user.Roles.Contains("admin"))
                                {
                                    <span class="text-muted">Админ</span>
                                }
                                else
                                {
                                    <span class="text-muted">Оператор</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-8">
                        <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class="h-fit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-line-icon lucide-pencil-line text-muted hover:text-primary-hover"><path d="M13 21h8" /><path d="m15 5 4 4" /><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z" /></svg>
                        </a>
                        <form asp-action="RemoveUser" method="post" class="leading-0 h-fit ">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" onclick="return confirm('Удалить пользователя?')" class="cursor-pointer">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2-icon lucide-trash-2 text-muted hover:text-red-400"><path d="M10 11v6" /><path d="M14 11v6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" /><path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                            </button>
                        </form>
                    </div>
                </div>
                <hr class="text-muted/20" />

                <div class="flex justify-between">
                    <div class="flex flex-col">
                        <span class="text-sm uppercase text-muted">Услуга</span>
                        <span>@user.ServiceName</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-sm uppercase text-muted">Окно</span>
                        <span>Окно №@user.WindowName</span>
                    </div>
                    <div></div>
                </div>
                <hr class="text-muted/20"/>
                
                <div class="flex justify-start">
                    @if (user.Status.ToString() == "Waiting")
                    {
                        <div class="flex items-center gap-2 py-1 px-3 rounded-full bg-green-100 text-green-700 text-sm tracking-wide font-bold">
                            <span class="block bg-green-700 h-1.75 w-1.75 rounded-full"></span>Ожидает
                        </div>
                    }
                    else if (user.Status.ToString() == "Away")
                    {
                        <div class="status-badge">
                            <div class="flex items-center gap-2 py-1 px-3 rounded-full bg-amber-100 text-amber-700 text-sm tracking-wide font-bold">
                                <span class="block bg-amber-700 h-1.75 w-1.75 rounded-full"></span>Отошёл
                            </div>
                            
                        </div>
                    }
                    else if (user.Status.ToString() == "Busy")
                    {
                        <div class="status-badge">
                            <div class="flex items-center gap-2 py-1 px-3 rounded-full bg-red-100 text-red-700 text-sm tracking-wide font-bold">
                                <span class="block bg-red-700 h-1.75 w-1.75 rounded-full"></span>Занят
                            </div>
                            
                        </div>
                    } 
                </div>
                
            </div>
        }
        <a asp-controller="Admin" asp-action="AddUser" class="flex flex-col text-3xl justify-center items-center rounded-2xl border border-dashed border-muted bg-primary-soft text-primary ">
            <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus text-muted mb-2"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            <span>Добавить</span>
            <span>сотрудника</span>
        </a>
        </div>
</div>