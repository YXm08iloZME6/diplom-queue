@model List<Application.DTOs.UserDto>

@{
    ViewData["Title"] = "Список сотрудников";
}

<div class="flex flex-col">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Список сотрудников</h1>
            <p class="text-slate-500 mt-2">Управление сотрудниками</p>
        </div>

        <a asp-controller="Admin" asp-action="AddUser" class="px-6 py-3 rounded-xl bg-blue-600 text-white font-medium hover:bg-blue-700 transition">
            + Добавить сотрудника
        </a>
    </div>

    <div class="overflow-x-auto rounded-2xl shadow border border-gray-200 bg-white">
        <table class="min-w-full text-left">
            <thead class="bg-gray-100 text-gray-700">
                <tr>
                    <th class="px-5 py-4 font-semibold">Имя</th>
                    <th class="px-5 py-4 font-semibold">Фамилия</th>
                    <th class="px-5 py-4 font-semibold">Отчество</th>
                    <th class="px-5 py-4 font-semibold">Email</th>
                    <th class="px-5 py-4 font-semibold">Статус</th>
                    <th class="px-5 py-4 font-semibold">Роли</th>
                    <th class="px-5 py-4 font-semibold">Окно</th>
                    <th class="px-5 py-4 font-semibold">Действия</th>
                </tr>
            </thead>
            
            <tbody class="divide-y divide-gray-200">
                @foreach (var user in Model)
                {
                    <tr class="bg-white hover:bg-gray-50 transition">
                        <td class="px-5 py-4 text-gray-600">@(user.Name ?? "-")</td>
                        <td class="px-5 py-4 text-gray-600">@(user.Surname ?? "-")</td>
                        <td class="px-5 py-4 text-gray-600">@(user.MiddleName ?? "-")</td>
                        <td class="px-5 py-4 text-gray-600">@(user.Email ?? "-")</td>

                        <td class="px-5 py-4">
                            @if (user.Status.ToString() == "Waiting")
                            {
                                <span class="status-badge">
                                    🟢 Ожидает
                                </span>
                            }
                            else if (user.Status.ToString() == "Away")
                            {
                                <span class="status-badge">
                                    🟡 Отошёл
                                </span>
                            }
                            else if (user.Status.ToString() == "Busy")
                            {
                                <span class="status-badge">
                                    🔴 Занят
                                </span>
                            }
                        </td>

                        <td class="px-4 py-4">
                            @(string.Join(", ", user.Roles))
                        </td>

                        <td class="px-4 py-4 text-center">
                            @(user.WindowName)
                        </td>

                        <td class="px-4 py-4">
                            <div class="flex gap-2">
                                <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class="px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm">
                                    ✏️
                                </a>
                                <form asp-action="RemoveUser" method="post" style="display:inline;" class="px-4 py-2 rounded-xl bg-red-100 hover:bg-red-200 text-sm text-red-600">
                                    <input type="hidden" name="id" value="@user.Id"/>
                                    <button type="submit" onclick="return confirm('Удалить пользователя?')">
                                        🗑️
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>