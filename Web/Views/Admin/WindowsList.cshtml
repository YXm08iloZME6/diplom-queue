@model List<Application.DTOs.WindowDto>

@{
    ViewData["Title"] = "Список окон";
    var sortedWindows = Model?.OrderBy(w => w.Number).ToList();
}

<div class="flex flex-col">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Окна обслуживания</h1>
            <p class="text-slate-500 mt-2">Управление рабочими окнами операторов</p>
        </div>

        <a asp-action="CreateWindow"
           class="flex items-center gap-4 text-white bg-primary rounded-xl py-2 px-4 border cursor-pointer">
            <span class="text-2xl">+</span> Добавить окно
        </a>
    </div>

    <div class="overflow-x-auto rounded-2xl shadow border border-gray-200 bg-white">
        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full min-w-full text-left">
                    <thead class="bg-primary-soft text-gray-700">
                        <tr>
                            <th class="px-5 py-4 font-semibold">Номер</th>
                            <th class="px-5 py-4 font-semibold">Статус</th>
                            <th class="px-5 py-4 font-semibold">Услуга</th>
                            <th class="px-5 py-4 font-semibold">Действия</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var window in sortedWindows!)
                        {
                            <tr class="border-t border-slate-100 hover:bg-slate-50 transition">
                                <td class="px-6 py-4 font-semibold text-slate-800">@window.Number</td>

                                <td class="px-6 py-4">
                                    @if (window.Status.ToString() == "Open")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">
                                            🟢 Открыто
                                        </span>
                                    }
                                    else if (window.Status.ToString() == "Busy")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">
                                            🔴 Занято
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-600">@window.Status</span>
                                    }

                                </td>
                                <td class="px-6 py-4 text-slate-600">@window.ServiceName</td>
                                <td>
                                    <div class="flex gap-2">
                                        <a asp-action="EditWindow" asp-route-id="@window.Id" class="px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200">✏️</a>
                                        <form asp-action="DeleteWindow" method="post">
                                            <input type="hidden" name="id" value="@window.Id" />
                                            <button type="submit" class="px-4 py-2 rounded-xl bg-red-100 hover:bg-red-200 text-red-600">🗑</button>
                                        </form>
                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>
                </table>

            </div>
        }
        else
        {
            <div class="p-16 text-center">

                <div class="text-6xl mb-4">🪟</div>

                <h3 class="text-xl font-semibold text-slate-700 mb-2">
                    Окна не найдены
                </h3>

                <p class="text-slate-500">
                    Пока не создано ни одного окна обслуживания
                </p>

            </div>
        }

    </div>

</div>