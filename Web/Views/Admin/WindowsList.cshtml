@model List<Application.DTOs.WindowDto>

@{
    ViewData["Title"] = "Список окон";
}

<div class="min-h-screen w-full bg-slate-50 px-10 py-8">
    <div class="flex justify-between items-center mb-10">

        <div>
            <h1 class="text-3xl font-bold text-slate-800">
                Окна обслуживания
            </h1>

            <p class="text-slate-500 mt-2">
                Управление рабочими окнами операторов
            </p>
        </div>

        <a asp-action="CreateWindow"
           class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-2xl transition shadow-sm">
            + Создать окно
        </a>

    </div>

    <div class="w-full bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">

        <div class="px-6 py-5 border-b border-slate-200 flex justify-between items-center">

            <h2 class="text-xl font-semibold text-slate-800">
                Всего окон: @(Model?.Count ?? 0)
            </h2>

        </div>

        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">

                <table class="w-full min-w-full">

                    <thead class="bg-slate-100">
                        <tr>
                            <th class="text-left px-6 py-4 text-sm font-semibold text-slate-700">
                                Название
                            </th>

                            <th class="text-left px-6 py-4 text-sm font-semibold text-slate-700">
                                Статус
                            </th>

                            <th class="text-left px-6 py-4 text-sm font-semibold text-slate-700">
                                Услуга
                            </th>

                            <th class="text-left px-6 py-4 text-sm font-semibold text-slate-700">
                                Действия
                            </th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var window in Model)
                        {
                            <tr class="border-t border-slate-100 hover:bg-slate-50 transition">

                                <td class="px-6 py-4 font-semibold text-slate-800">
                                    @window.Title
                                </td>

                                <td class="px-6 py-4">

                                    @if (window.Status.ToString() == "Open")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">
                                            🟢 Открыто
                                        </span>
                                    }
                                    else if (window.Status.ToString() == "Busy")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">
                                            🔴 Занято
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-600">
                                            @window.Status
                                        </span>
                                    }

                                </td>

                                <td class="px-6 py-4 text-slate-600">
                                    @window.ServiceName
                                </td>

                            </tr>
                        }

                    </tbody>
                </table>

            </div>
        }
        else
        {
            <div class="p-16 text-center">

                <div class="text-6xl mb-4">🪟</div>

                <h3 class="text-xl font-semibold text-slate-700 mb-2">
                    Окна не найдены
                </h3>

                <p class="text-slate-500">
                    Пока не создано ни одного окна обслуживания
                </p>

            </div>
        }

    </div>

</div>