@model List<Application.DTOs.ServiceDto>

@{
    ViewData["Title"] = "Список услуг";
}

<div class="flex flex-col">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Список услуг</h1>
            <p class="text-slate-500 mt-2">Управление услугами</p>
        </div>
        <a asp-controller="Admin" asp-action="CreateWindow" class="px-6 py-3 rounded-xl bg-blue-600 text-white font-medium hover:bg-blue-700 transition">+ Добавить услугу</a>
    </div>

    <div class="overflow-x-auto rounded-2xl shadow border border-gray-200 bg-white">
        <table class="min-w-full text-left">
            <thead class="bg-gray-100 text-gray-700">
                <tr>
                    <th class="px-5 py-4 font-semibold">Название</th>
                    <th class="px-5 py-4 font-semibold">Буква</th>
                    <th class="px-5 py-4 font-semibold">Описание</th>
                    <th class="px-5 py-4 font-semibold">Активный?</th>
                    <th class="px-5 py-4 font-semibold">Доп. информация</th>
                    <th class="px-5 py-4 font-semibold">Действия</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200">
                @foreach (var service in Model)
                {
                    <tr class="bg-white hover:bg-gray-50 transition">
                        <td class="px-5 py-4 font-semibold text-gray-800">@service.Name</td>
                        <td class="px-5 py-4 text-gray-600">@service.Letter</td>
                        <td class="px-5 py-4 text-gray-600 max-w-md">@service.Description</td>
                        
                        <td class="px-5 py-4">
                            <form asp-action="ToggleServiceStatus" method="post">
                                <input type="hidden" name="id" value="@service.Id" />

                                <button type="submit"
                                        class="relative inline-flex h-7 w-14 items-center rounded-full transition
                                        @(service.IsActive ? "bg-green-500" : "bg-gray-300")">

                                    <span class="inline-block h-5 w-5 transform rounded-full bg-white shadow transition
                                        @(service.IsActive ? "translate-x-8" : "translate-x-1")">
                                    </span>
                                </button>
                            </form>
                        </td>

                        <td class="px-5 py-4">
                            <form asp-action="ToggleServiceFacets" method="post">
                                <input type="hidden" name="id" value="@service.Id" />

                                <button type="submit"
                                        class="relative inline-flex h-7 w-14 items-center rounded-full transition
                                        @(service.IsNeedFacets ? "bg-blue-600" : "bg-gray-300")">

                                    <span class="inline-block h-5 w-5 transform rounded-full bg-white shadow transition
                                        @(service.IsNeedFacets ? "translate-x-8" : "translate-x-1")">
                                    </span>
                                </button>
                            </form>
                        </td>

                        <td class="px-4 py-4">
                            <div class="flex gap-2">
                                <a asp-action="EditService"asp-route-id="@service.Id" class="px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm">✏️</a>

                                <form asp-action="DeleteService" method="post">
                                    <input type="hidden" name="id" value="@service.Id" />
                                    <button type="submit" class="px-4 py-2 rounded-xl bg-red-100 hover:bg-red-200 text-sm text-red-600">🗑</button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    @foreach (var child in service.Children)
                    {
                        <tr class="bg-gray-50 hover:bg-gray-100 transition">
                            <td class="px-5 py-4 pl-14 text-gray-700">
                                ↳ @child.Name
                            </td>
                            <td class="px-5 py-4 text-gray-600">
                                @child.Letter
                            </td>
                            <td class="px-5 py-4 text-gray-600 max-w-md">
                                @child.Description
                            </td>

                            <td class="px-5 py-4">
                                <form asp-action="ToggleServiceStatus" method="post">
                                    <input type="hidden" name="id" value="@child.Id" />

                                    <button type="submit"
                                            class="relative inline-flex h-7 w-14 items-center rounded-full transition
                                            @(child.IsActive ? "bg-green-500" : "bg-gray-300")">

                                        <span class="inline-block h-5 w-5 transform rounded-full bg-white shadow transition
                                            @(child.IsActive ? "translate-x-8" : "translate-x-1")">
                                        </span>
                                    </button>
                                </form>
                            </td>

                            <td class="px-5 py-4">
                                <form asp-action="ToggleServiceFacets" method="post">
                                    <input type="hidden" name="id" value="@child.Id" />

                                    <button type="submit"
                                            class="relative inline-flex h-7 w-14 items-center rounded-full transition
                                            @(child.IsNeedFacets ? "bg-blue-600" : "bg-gray-300")">

                                        <span class="inline-block h-5 w-5 transform rounded-full bg-white shadow transition
                                            @(child.IsNeedFacets ? "translate-x-8" : "translate-x-1")">
                                        </span>
                                    </button>
                                </form>
                            </td>

                            <td class="px-4 py-4">
                                <div class="flex gap-2">
                                    <a asp-action="EditService" asp-route-id="@child.Id" class="px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm">✏️</a>

                                    <form asp-action="DeleteService" method="post">
                                        <input type="hidden" name="id" value="@child.Id" />
                                        <button type="submit" class="px-4 py-2 rounded-xl bg-red-100 hover:bg-red-200 text-sm text-red-600">🗑</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>