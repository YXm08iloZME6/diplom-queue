@model Application.DTOs.ServiceDto

<div class="max-w-3xl mx-auto py-10 px-6">

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8">

        <h1 class="text-3xl font-bold text-slate-800 mb-8">Редактирование услуги</h1>

        <form asp-action="EditService" method="post" class="space-y-6">

            <input type="hidden" asp-for="Id" />

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">
                    Название
                </label>

                <input asp-for="Name"
                       class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">
                    Буква
                </label>

                <input asp-for="Letter"
                       class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">
                    Описание
                </label>

                <textarea asp-for="Description"
                          rows="4"
                          class="w-full rounded-2xl border border-slate-300 px-4 py-3"></textarea>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">
                    Иконка
                </label>

                <input asp-for="IconName"
                       class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
            </div>

            <div class="flex gap-4 pt-4">

                <button type="submit"
                        class="px-6 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition">
                    Сохранить
                </button>

                <a asp-action="ServiceList"
                   class="px-6 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold transition">
                    Назад
                </a>

            </div>

        </form>
    </div>
</div>