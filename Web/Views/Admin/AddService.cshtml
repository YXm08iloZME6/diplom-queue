@model Web.Models.CreateServiceViewModel

<h2>Добавить услугу</h2>

<form asp-action="AddService" asp-controller="Admin" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Service.Name"></label>
        <input asp-for="Service.Name" class="form-control" />
        <span asp-validation-for="Service.Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Service.Letter"></label>
        <input asp-for="Service.Letter" class="form-control" />
        <span asp-validation-for="Service.Letter" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Service.Description"></label>
        <textarea asp-for="Service.Description" class="form-control"></textarea>
        <span asp-validation-for="Service.Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Service.IconName"></label>
        <input asp-for="Service.IconName" class="form-control" />
        <span asp-validation-for="Service.IconName" class="text-danger"></span>
    </div>

    <select asp-for="Service.ParentId" class="...">
        <option value="">Нет родителя</option>
        @foreach (var service in Model.AvailableParents)
        {
            <option value="@service.Id">@service.Name</option>
        }
    </select>

    <button type="submit" class="btn btn-primary">Добавить</button>
    <a asp-action="ServiceList">Отмена</a>
</form>