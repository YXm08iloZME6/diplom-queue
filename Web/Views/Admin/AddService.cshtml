@model Web.Models.CreateServiceViewModel

<div class="max-w-3xl mx-auto py-10 px-6">

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8">

        <h1 class="text-3xl font-bold text-slate-800 mb-8">Добавление услуги</h1>

        <form asp-action="AddService" asp-controller="Admin" method="post" class="space-y-6">

            <div asp-validation-summary="ModelOnly" class="rounded-2xl bg-red-50 border border-red-200 text-red-600 px-4 py-3 text-sm"></div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">Название</label>
                <input asp-for="Service.Name" class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
                <span asp-validation-for="Service.Name" class="text-sm text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">Буква</label>
                <input asp-for="Service.Letter" class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
                <span asp-validation-for="Service.Letter" class="text-sm text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">Описание</label>
                <textarea asp-for="Service.Description" class="w-full rounded-2xl border border-slate-300 px-4 py-3"></textarea>
                <span asp-validation-for="Service.Description" class="text-sm text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">Иконка</label>
                <input asp-for="Service.IconName" class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
                <span asp-validation-for="Service.IconName" class="text-sm text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium text-slate-700">Родительская услуга</label>
                <select asp-for="Service.ParentId" class="w-full rounded-2xl border border-slate-300 px-4 py-3">
                    <option value="">Нет родителя</option>
                    @foreach (var service in Model.AvailableParents)
                    {
                        <option value="@service.Id">@service.Name</option>
                    }
                </select>
            </div>

            <div class="flex gap-4 pt-4">

                <button type="submit" class="px-6 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition">
                    Добавить
                </button>

                <a asp-action="ServiceList" class="px-6 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold transition">
                    Отмена
                </a>

            </div>

        </form>

    </div>

</div>