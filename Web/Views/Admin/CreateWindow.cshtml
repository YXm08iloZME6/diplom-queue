@model Web.Models.CreateWindowViewModel

@{
    ViewData["Title"] = "Создание окна";
}

<div class="min-h-screen bg-slate-50 py-10 px-6">

    <div class="max-w-3xl mx-auto">

        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-800 mb-2">@ViewData["Title"]</h1>
            <p class="text-slate-500">Создание и настройка нового окна обслуживания</p>
        </div>

        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">

            <div class="px-8 py-6 border-b border-slate-200 bg-slate-50">
                <h2 class="text-xl font-semibold text-slate-800">Информация об окне</h2>
            </div>

            <form asp-action="CreateWindow" method="post" class="p-8 space-y-6">

                <div asp-validation-summary="ModelOnly"
                     class="rounded-2xl bg-red-50 border border-red-200 text-red-600 px-4 py-3 text-sm">
                </div>

                <div>
                    <label asp-for="Window.Number" class="block mb-2 text-sm font-semibold text-slate-700">Название окна</label>
                    <input asp-for="Window.Number" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                    <span asp-validation-for="Window.Number" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Window.Status" class="block mb-2 text-sm font-semibold text-slate-700">Статус</label>
                    <select asp-for="Window.Status" asp-items="Html.GetEnumSelectList<Domain.Enums.WindowStatus>()" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"></select>
                    <span asp-validation-for="Window.Status" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Window.ServiceId" class="block mb-2 text-sm font-semibold text-slate-700">Услуга</label>
                    <select asp-for="Window.ServiceId" class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                        <option value="">Не выбрано</option>
                        @foreach (var service in Model.Services)
                        {
                            <option value="@service.Id">
                                @service.Name
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Window.ServiceId" class="text-sm text-red-500 mt-1 block"></span>
                </div>

                <div class="flex items-center gap-4 pt-4">
                    <button type="submit" class="px-6 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition shadow-sm">Создать окно</button>
                    <a asp-action="WindowsList" class="px-6 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold transition">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>