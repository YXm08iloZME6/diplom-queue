@model Web.Models.OperatorDashboardViewModel

@{
    ViewData["Title"] = "Рабочее место оператора";
}

<div class="h-fit bg-[#F4F7FA] p-8 font-sans text-slate-700">

    <header class="max-w-6xl mx-auto mb-8 flex justify-between items-center px-4">
        <div>
            <h1 class="text-2xl font-semibold text-slate-800">Панель оператора</h1>
            <p class="text-sm text-slate-500">Окно номер @Model.windowName — @Model.serviceName</p>
        </div>

        <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-slate-600">@User.Identity?.Name</span>
            <div class="w-9 h-9 rounded-full bg-white border border-slate-200 flex items-center justify-center shadow-sm">
                <span class="text-xs">👤</span>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto grid grid-cols-12 gap-6">

        <div class="col-span-12 lg:col-span-7">
            <div class="bg-white rounded-3xl border border-slate-200/60 shadow-sm p-12 h-full flex flex-col items-center justify-center text-center">

                @if (Model.dashboard.CurrentTicket != null)
                {
                    <span class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-4">Сейчас в обслуживании</span>
                    <div class="text-8xl font-light text-slate-900 tracking-tight mb-6">
                        @Model.dashboard.CurrentTicket.Number
                    </div>
                    <div class="px-4 py-1.5 bg-slate-50 border border-slate-100 rounded-full text-xs font-semibold text-slate-500 mb-10 uppercase tracking-wide">
                        Статус: @Model.dashboard.CurrentTicket.Status
                    </div>
                }
                else
                {
                    <div class="py-12">
                        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">☕</div>
                        <h2 class="text-xl font-medium text-slate-400">Очередь свободна</h2>
                    </div>
                }

                <div class="w-full max-w-md space-y-3">
                    @if (Model.dashboard.CurrentTicket == null)
                    {
                        <form asp-action="CallNext" method="post">
                            <button type="submit" class="w-full bg-[#3B82F6] hover:bg-[#2563EB] text-white font-medium py-4 rounded-2xl transition-all duration-200 shadow-sm active:transform active:scale-[0.99]">
                                Вызвать следующего клиента
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 gap-3">
                            @if (Model.dashboard.CurrentTicket.Status == "Called")
                            {
                                <form asp-action="StartProcessing" method="post">
                                    <input type="hidden" name="ticketId" value="@Model.dashboard.CurrentTicket.Id" />
                                    <button type="submit" class="w-full bg-[#10B981] hover:bg-[#059669] text-white font-medium py-3.5 rounded-xl transition-all">
                                        Начать обслуживание
                                    </button>
                                </form>
                                <div class="grid grid-cols-2 gap-3">
                                    <form asp-action="Recall" method="post">
                                        <input type="hidden" name="ticketId" value="@Model.dashboard.CurrentTicket.Id" />
                                        <button type="submit" class="w-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 font-medium py-3 rounded-xl transition-all">
                                            Повторить вызов
                                        </button>
                                    </form>
                                    <form asp-action="Cancel" method="post">
                                        <input type="hidden" name="ticketId" value="@Model.dashboard.CurrentTicket.Id" />
                                        <button type="submit" class="w-full bg-white border border-slate-200 text-red-500 hover:bg-red-50 font-medium py-3 rounded-xl transition-all">
                                            Отменить
                                        </button>
                                    </form>
                                </div>
                            }

                            @if (Model.dashboard.CurrentTicket.Status == "Processing")
                            {
                                <form asp-action="Complete" method="post">
                                    <input type="hidden" name="ticketId" value="@Model.dashboard.CurrentTicket.Id" />
                                    <button type="submit" class="w-full bg-[#3B82F6] hover:bg-[#2563EB] text-white font-medium py-4 rounded-xl shadow-sm transition-all">
                                        Завершить прием
                                    </button>
                                </form>
                                <div class="space-y-3">

                                    <select id="targetService"
                                            class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4">
                                        <option value="">Выберите услугу...</option>

                                        @foreach (var service in Model.dashboard.AllServices)
                                        {
                                            <option value="@service.Id">
                                                @service.Name
                                            </option>
                                        }
                                    </select>

                                    <button type="button"
                                            onclick="openRedirectModal()"
                                            class="w-full bg-amber-500 hover:bg-amber-600 text-white font-medium py-3 rounded-xl">
                                        Перенаправить клиента
                                    </button>

                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-span-12 lg:col-span-5">
            <div class="bg-white rounded-3xl border border-slate-200/60 shadow-sm p-6 h-full">
                <div class="flex items-center justify-between mb-6 px-2">
                    <h2 class="font-semibold text-slate-800">Ожидают в очереди</h2>
                    <span class="text-xs font-bold bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full">
                        @(Model.dashboard.WaitingTickets?.Count() ?? 0)
                    </span>
                </div>

                <div class="space-y-2">
                    @if (Model.dashboard.WaitingTickets != null && Model.dashboard.WaitingTickets.Any())
                    {
                        @foreach (var ticket in Model.dashboard.WaitingTickets)
                        {
                            <div class="flex items-center justify-between p-4 bg-slate-50/50 border border-slate-100 rounded-2xl hover:bg-white hover:border-blue-200 hover:shadow-sm transition-all group">
                                <span class="font-semibold text-slate-700 group-hover:text-blue-600">@ticket.Number</span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider bg-white px-2 py-1 rounded border border-slate-100">
                                    @ticket.Status
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-10 border-2 border-dashed border-slate-100 rounded-2xl">
                            <p class="text-sm text-slate-400">Список пуст</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>


    <div id="redirectModal"
         class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">

        <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6">

            <h2 class="text-xl font-semibold text-slate-800 mb-4">
                Перенаправление клиента
            </h2>

            <form asp-action="Redirect" method="post">

                <input type="hidden"
                       id="modalServiceId"
                       name="serviceId" />

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-2">
                        Комментарий
                    </label>

                    <textarea name="comment"
                              rows="4"
                              placeholder="Причина перенаправления..."
                              class="w-full rounded-xl border border-slate-300 px-4 py-3 resize-none"></textarea>
                </div>

                <div class="flex gap-3">

                    <button type="button"
                            onclick="closeRedirectModal()"
                            class="flex-1 border border-slate-300 rounded-xl py-3">
                        Отмена
                    </button>

                    <button type="submit"
                            class="flex-1 bg-blue-600 text-white rounded-xl py-3 hover:bg-blue-700">
                        Перенаправить
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/queue")
        .withAutomaticReconnect()
        .build();

    connection.on("NewTicket", () => {
        window.location.reload();
    });

    connection.start().catch(err => console.error(err));

    function openRedirectModal() {

        const serviceId =
            document.getElementById("targetService").value;

        if (!serviceId) {
            alert("Сначала выберите услугу");
            return;
        }

        document.getElementById("modalServiceId").value =
            serviceId;

        const modal =
            document.getElementById("redirectModal");

        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closeRedirectModal() {

        const modal =
            document.getElementById("redirectModal");

        modal.classList.add("hidden");
        modal.classList.remove("flex");
    }
</script>