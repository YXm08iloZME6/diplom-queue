@model Application.DTOs.OperatorDashboardDto

@{
    ViewData["Title"] = "Рабочее место оператора";
}

<div class="operator-page">
    <div class="operator-header">
        <h1>Рабочее место оператора</h1>
        <div class="operator-user">
            <span>@User.Identity?.Name</span>
        </div>
    </div>

    <div class="operator-grid">
        <div class="operator-card">
            <h2>Текущий клиент</h2>

            @if (Model.CurrentTicket != null)
            {
                <div class="ticket-number-row">
                    <div class="ticket-number">
                        @Model.CurrentTicket.Number
                    </div>

                    <span class="ticket-status">
                        @Model.CurrentTicket.Status
                    </span>
                </div>
            }
            else
            {
                <div class="ticket-empty">
                    Сейчас активного клиента нет
                </div>
            }

            @if (Model.CurrentTicket == null)
            {
                <form asp-action="CallNext" method="post">
                    <button class="main-btn" type="submit">
                        Вызвать следующего
                    </button>
                </form>
            }

            @if (Model.CurrentTicket != null)
            {
                <div class="action-buttons">
                    <form asp-action="StartProcessing" method="post">
                        <input type="hidden" name="ticketId" value="@Model.CurrentTicket.Id" />
                        <button type="submit">На обслуживание</button>
                    </form>

                    <form asp-action="Recall" method="post">
                        <input type="hidden" name="ticketId" value="@Model.CurrentTicket.Id" />
                        <button type="submit">Перевызвать</button>
                    </form>

                    <form asp-action="Complete" method="post">
                        <input type="hidden" name="ticketId" value="@Model.CurrentTicket.Id" />
                        <button type="submit">Завершить</button>
                    </form>

                    <form asp-action="Cancel" method="post">
                        <input type="hidden" name="ticketId" value="@Model.CurrentTicket.Id" />
                        <button type="submit">Отменить</button>
                    </form>

                    <form asp-action="Redirect" method="post">
                        <select name="serviceId" class="main-btn" onchange="this.form.submit()">
                            <option value="" disabled selected>Выберите услугу для перенаправления...</option>
                            @foreach (var service in Model.AllServices)
                            {
                                <option value="@service.Id">@service.Name</option>
                            }
                        </select>
                    </form>
                </div>
            }
        </div>

        <div class="operator-card">
            <h2>Список ожидающих клиентов</h2>

            <table class="queue-table">
                <thead>
                    <tr>
                        <th>Номер талона</th>
                        @* <th>Услуга</th> *@
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.WaitingTickets != null && Model.WaitingTickets.Any())
                    {
                        @foreach (var ticket in Model.WaitingTickets)
                        {
                            <tr>
                                <td>@ticket.Number</td>
                                @* <td>@ticket.ServiceName</td> *@
                                <td>@ticket.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">Очередь пуста</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="back-link">
        <a asp-controller="Home" asp-action="Index">← Назад в панель</a>
    </div>
</div>

<style>
.operator-page {
    max-width: 1200px;
    margin: 40px auto;
    padding: 20px;
}

.operator-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.operator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.operator-card {
    background: white;
    border-radius: 18px;
    padding: 28px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
}

.ticket-number-row {
    display: flex;
    align-items: center;
    gap: 16px;
}

.ticket-number {
    font-size: 42px;
    font-weight: 700;
}

.ticket-status {
    background: #f3f4f6;
    padding: 8px 14px;
    border-radius: 10px;
    font-size: 14px;
}

.ticket-service {
    margin: 16px 0 24px;
    font-size: 18px;
}

.main-btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    cursor: pointer;
}

.action-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 20px;
}

.action-buttons button {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
}

.queue-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
}

.queue-table th,
.queue-table td {
    text-align: left;
    padding: 14px;
    border-bottom: 1px solid #eee;
}

.back-link {
    margin-top: 24px;
}
</style>