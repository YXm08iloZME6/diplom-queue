@model Application.DTOs.ServiceDto

@{
    ViewBag.Title = "title";
    Layout = "_KioskLayout";
}

<div class="container mx-auto flex grow justify-center pt-10">
    <div class="flex flex-col gap-12 items-center">
        <div class="flex flex-col items-center text-center">
            <h1 class="text-3xl tracking-wide uppercase font-bold">@(Model.Name)</h1>
            <p class="mt-2 tracking-wide text-lg text-dark max-w-8/12 ">@Model.Description</p>
        </div>

        <div class="grid grid-cols-2 gap-4 max-w-8/12">
            @foreach (var service in @Model.Children)
            {
                <a asp-controller="Service" asp-action="Select" asp-route-id="@service.Id" class="bg-white rounded-3xl p-6 border shadow-sm flex flex-col gap-3 cursor-pointer">
                    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-slate-600">
                        <img src="~/icons/@(service.IconName).svg" alt="@service.Name" width="28" height="28"/>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-secondary tracking-wide">@service.Name</h3>
                        <p class="text-dark leading-tight">@service.Description</p>
                    </div>
                    <div class="bg-primary/10 w-fit py-1 px-2 font-normal rounded-full text-sm flex gap-1 items-center">
                        <img src="~/icons/Clock2.svg" alt="" width="12" height="12"/>
                        8 мин
                    </div>
                </a>
            }
        </div>
        <a class="text-dark text-xl rounded-3xl p-4 border shadow-sm" asp-area="" asp-controller="Service" asp-action="Index">Вернуться назад</a>
    </div>
</div>
