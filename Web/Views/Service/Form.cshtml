@model Application.DTOs.ServiceDto

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<form class="flex flex-col gap-8 h-fit w-full max-w-xl bg-white rounded-3xl p-12 shadow-lg" name="info-form" asp-controller="Service" asp-action="GetTicket" method="post" asp-route-serviceId="@Model.Id" asp-route-letter="@Model.Letter">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tight mb-1">@Model.Name</h1>
        <p class="text-muted-foreground text-lg">Введите данные для получения талона</p>
    </div>
    <div class="flex flex-col gap-2">
        <label for="phoneNumber" class="text-xl font-semibold">Номер телефона</label>
        <input id="phoneNumber" name="phoneNumber" placeholder="+79953357878" class="h-16 w-full rounded-2xl border-2 border-input bg-transparent px-5 text-2xl transition-colors outline-none focus:border-ring placeholder:text-muted-foreground"/>
    </div>
    <div class="flex flex-col gap-2">
        <label for="fullName" class="text-xl font-semibold">Имя</label>
        <input id="fullName" name="fullName" placeholder="Введите имя" class="h-16 w-full rounded-2xl border-2 border-input bg-transparent px-5 text-2xl transition-colors outline-none focus:border-ring placeholder:text-muted-foreground"/>
    </div>
    <button type="submit" class="h-16 bg-primary text-primary-foreground rounded-2xl text-2xl font-semibold tracking-wide mt-2 cursor-pointer active:opacity-80 transition-opacity">Получить талон</button>
</form>