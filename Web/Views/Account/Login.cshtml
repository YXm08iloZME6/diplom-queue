@model Application.DTOs.LoginUserDto

<div class="login-container">
    <h2>Вход на сайт</h2>
    

    <form asp-action="Login" asp-controller="Account" asp-anti-forgery="true" class="login-form">
        <div class="validation" asp-validation-summary="ModelOnly"></div>

        <div class="form-group">
            <label asp-for="Email">Введите Email</label>
            <input type="email" asp-for="Email" placeholder="example@company.com" />
            <span class="field-validation-error" asp-validation-for="Email"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Введите пароль</label>
            <input type="password" asp-for="Password" placeholder="Введите ваш пароль" />
            <span class="field-validation-error" asp-validation-for="Password"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="login-btn">Войти</button>
        </div>

        <div class="login-link">
            Нет аккаунта? <a asp-action="Register" asp-controller="Account">Зарегистрироваться</a>
        </div>

    </form>
</div>