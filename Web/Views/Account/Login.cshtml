@model Application.DTOs.LoginUserDto

<div class="min-h-screen flex items-center justify-center p-4" style="margin: 0; position: fixed; top: 0; left: 0; right: 0; bottom: 0;">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">
        <h2 class="px-8 pt-8 pb-6 border-b border-slate-100 text-2xl font-semibold text-slate-800 tracking-tight m-0">Вход на сайт</h2>

        <form asp-action="Login" asp-controller="Account" asp-anti-forgery="true" class="px-8 py-6">
            <div class="mb-5 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm" asp-validation-summary="ModelOnly"></div>

            <div class="mb-5">
                <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-2">Введите Email</label>
                <input type="email" asp-for="Email" placeholder="example@company.com" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 text-slate-700 placeholder-slate-400" />
                <span class="text-xs text-red-500 mt-1 block" asp-validation-for="Email"></span>
            </div>

            <div class="mb-6">
                <label asp-for="Password" class="block text-sm font-medium text-slate-700 mb-2">Введите пароль</label>
                <input type="password" asp-for="Password" placeholder="Введите ваш пароль" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 text-slate-700 placeholder-slate-400" />
                <span class="text-xs text-red-500 mt-1 block" asp-validation-for="Password"></span>
            </div>

            <div>
                <button type="submit" class="w-full text-white font-medium py-2.5 rounded-xl transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5" style="background: #0a58ca;">Войти</button>
            </div>
        </form>
    </div>
</div>