@model Application.DTOs.DisplayDto

@{
    ViewBag.Title = "Экран ожидания";
    Layout = "_KioskLayout";
}

<div class="grid grid-cols-3 gap-8 p-10 h-full">
    <div class="col-span-2 bg-transparent rounded-2xl p-5 flex flex-col gap-3 cursor-pointer">
        <h2 class="text-3xl tracking-wide font-bold text-ink"></h2>
        <div id="active-list" class="grid grid-cols-2 auto-rows-fr h-full gap-4 mt-4">
            @await Html.PartialAsync("ActiveList", Model)
        </div>
    </div>
        
    <div class="bg-white rounded-2xl p-5 border border-line flex flex-col gap-3 cursor-pointer">
        <h2 class="text-2xl tracking-wide font-bold text-ink">Очередь</h2>
        <div id="waiting-list" class="flex flex-col gap-4 mt-4">
            @await Html.PartialAsync("WaitingList", Model)
        </div>
    </div>
</div>

<audio id="recall-sound" src="~/sounds/recall.mp3" preload="auto"></audio>
<script src="~/lib/microsoft-signalr/signalr.min.js" asp-append-version="true"></script>

<script>
    const recallSound = document.getElementById("recall-sound");
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/queue")
        .withAutomaticReconnect()
        .build();

    async function updateList(id, action) {
        const res = await fetch(action);
        document.getElementById(id).innerHTML = await res.text();
    }

    connection.on("NewTicket", () => {
        updateList("waiting-list", "@Url.Action("WaitingList", "Display")") 
    });
    
    connection.on("UpdateTicket", () => {
        updateList("waiting-list", "@Url.Action("WaitingList", "Display")") 
        updateList("active-list", "@Url.Action("ActiveList", "Display")") 
    });

    connection.on("CallTicket", () => {
        recallSound.play()
        
        updateList("waiting-list", "@Url.Action("WaitingList", "Display")")
        updateList("active-list", "@Url.Action("ActiveList", "Display")")
    });
    
    connection.on("RecallTicket", (ticket) => {
        recallSound.play()
        const el = document.getElementById("window-" + ticket.windowId);

        el.classList.add("ring-4", "ring-amber-400", "animate-pulse");
        setTimeout(() => {
            el.classList.remove("ring-4", "ring-amber-400", "animate-pulse");
        }, 4000);
    });

    connection.start();
</script>


