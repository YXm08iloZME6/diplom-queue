@model Application.DTOs.DisplayDto

@for (int i = 0; i < Model.WaitingTickets.Count; i++)
{
    var t = Model.WaitingTickets[i];
    <div class="bg-primary-soft rounded-xl p-4 flex">
        <div class="flex items-center gap-6">
            <span class="font-bold text-muted text-lg">@(i + 1)</span>
            <div class="flex flex-col">
                <span class="text-primary-deep font-bold tracking-wide text-xl">@t.TicketNumber</span>
                <span class="text-ink text-sm tracking-wide">@t.ServiceName</span>
            </div>
        </div>
    </div>
}