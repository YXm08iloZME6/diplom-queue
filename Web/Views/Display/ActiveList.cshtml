@model Application.DTOs.DisplayDto

@if (!Model.ActiveTickets.Any())
{
    <div class="col-span-2 text-center py-16 text-3xl text-slate-500">Нет окон</div>
}
else
{
    @foreach (var call in Model.ActiveTickets)
    {
        <div id="window-@call.WindowId"
             data-window-title="@call.Title"
             data-window-number="@call.WindowNumber"
             class="bg-white rounded-2xl py-10 px-6 text-center shadow-lg">
            <div class="text-2xl font-semibold text-sky-400 tracking-widest uppercase">@call.Title</div>
            <div class="window-number text-8xl font-extrabold text-black mt-4 tabular-nums">
                @(string.IsNullOrEmpty(call.TicketNumber) ? "—" : call.TicketNumber)
            </div>
        </div>
    }
}