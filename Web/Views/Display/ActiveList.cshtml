@model Application.DTOs.DisplayDto

@{
    Dictionary<string, string> status = new Dictionary<string, string>
    {
        { "Waiting", "Ожидание" }, 
        { "Processing", "Обслуживается" }, 
        { "Called", "Вызван" },
        { "Completed", "Завершён" }, 
        { "Cancelled", "Отменён" }
    };
}

@foreach (var call in Model.ActiveTickets)
{
    <div id="window-@call.WindowId" class="bg-white rounded-2xl border border-line p-5 flex flex-col justify-between">
        <div>
            <div class="font-bold text-xl text-muted tracking-widest uppercase">Окно №@call.WindowNumber</div>
            <div class="text-6xl font-extrabold text-primary-deep mt-4">
                @(string.IsNullOrEmpty(call.TicketNumber) ? "—" : call.TicketNumber)
            </div>
        </div>

        <div class="flex flex-col">
            <div class="pb-1 text-lg text-ink">
                @(string.IsNullOrEmpty(call.Status.ToString()) ? "" : status[call.Status.ToString()])
            </div>
            <div class="text-xl font-semibold text-ink tracking-widest">@call.ServiceName</div>
        </div>
    </div>
}




