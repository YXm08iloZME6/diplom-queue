@model Application.DTOs.DisplayDto

@{
    Dictionary<string, string> status = new Dictionary<string, string>
    {
        { "Waiting", "Ожидание" }, 
        { "Processing", "Обслуживается" }, 
        { "Called", "Вызван" },
        { "Completed", "Завершён" }, 
        { "Cancelled", "Отменён" }
    };
}

@foreach (var call in Model.ActiveTickets)
{
    <div id="window-@call.WindowId" class="bg-primary/10 rounded-3xl p-6 flex flex-col">
        <div class="flex items-end justify-between">
            <div class="text-2xl font-bold text-secondary tracking-widest uppercase">Окно №@call.WindowNumber</div>
            <div class="text-lg font-semibold text-dark tracking-widest uppercase">@call.Title</div>
        </div>

        <div class="flex items-end gap-4">
            <div class="text-6xl font-extrabold text-secondary mt-4">
                @(string.IsNullOrEmpty(call.TicketNumber) ? "—" : call.TicketNumber)
            </div>
            <div class="pb-1 text-lg text-dark">
                @(string.IsNullOrEmpty(call.Status.ToString()) ? "" : status[call.Status.ToString()])
            </div>
        </div>
    </div>
}




