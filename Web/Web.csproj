    <ItemGroup>
        <UpToDateCheckBuilt Include="wwwroot/css/input.css" Set="Css" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="wwwroot\icons\" />
      <Folder Include="wwwroot\uploads\avatars\" />
    </ItemGroup>
    <Target Name="Tailwind" BeforeTargets="Build;PrepareForPublish">
        <Exec Command="npm install" />
        <Exec Command="npx @tailwindcss/cli -i ./wwwroot/css/input.css -o ./wwwroot/css/output.css --minify" />
        
        <Copy SourceFiles="node_modules/@microsoft/signalr/dist/browser/signalr.min.js"
              DestinationFolder="wwwroot/lib/microsoft-signalr"
              SkipUnchangedFiles="true" />
        
        <ItemGroup>
            <Content Include="wwwroot/css/output.css" CopyToPublishDirectory="Always" />
            <Content Include="wwwroot/lib/microsoft-signalr/signalr.min.js" CopyToPublishDirectory="Always" />
        </ItemGroup>
    </Target>
</Project>
